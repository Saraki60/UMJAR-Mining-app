import React, { useState } from "react";

import { initializeApp } from "firebase/app";

import {
getAuth,
createUserWithEmailAndPassword,
signInWithEmailAndPassword,
signOut
} from "firebase/auth";

import {
getFirestore,
doc,
setDoc,
getDoc,
updateDoc
} from "firebase/firestore";

const firebaseConfig = {
apiKey: "AIzaSyAmLTvCWirFSpbpEpQTDX-4p3JAarIr3R4",
authDomain: "umjar-mining.firebaseapp.com",
projectId: "umjar-mining",
storageBucket: "umjar-mining.firebasestorage.app",
messagingSenderId: "908328509401",
appId: "1:908328509401:web:7e7e8ceb078efe500c43c8",
measurementId: "G-TE3NN8W0HT"
};

const app = initializeApp(firebaseConfig);

const auth = getAuth(app);

const db = getFirestore(app);

export default function UMJARExchange() {

const [email,setEmail] = useState("");

const [password,setPassword] = useState("");

const [user,setUser] = useState(null);

const [balance,setBalance] = useState(0);

const [mining,setMining] = useState(false);

const [investment,setInvestment] = useState(0);

const [referrals,setReferrals] = useState(0);

const [walletAddress,setWalletAddress] = useState("");

async function signup(){

try{

const res =
await createUserWithEmailAndPassword(
auth,
email,
password
);

await setDoc(
doc(db,"users",res.user.uid),
{
email,
balance:0,
mining:false,
investment:0,
referrals:0,
walletAddress:"",
withdrawPending:false
}
);

alert("Signup Success");

}catch(err){

alert(err.message);

}

}

async function login(){

try{

const res =
await signInWithEmailAndPassword(
auth,
email,
password
);

setUser(res.user);

const ref =
doc(db,"users",res.user.uid);

const snap =
await getDoc(ref);

if(snap.exists()){

setBalance(snap.data().balance);

setMining(snap.data().mining);

setInvestment(snap.data().investment);

setReferrals(snap.data().referrals);

setWalletAddress(
snap.data().walletAddress
);

}

alert("Login Success");

}catch(err){

alert(err.message);

}

}

async function logout(){

await signOut(auth);

setUser(null);

alert("Logged Out");

}

async function startMining(){

if(!user){

alert("Login First");

return;

}

const newBalance =
balance + 10;

setBalance(newBalance);

setMining(true);

await updateDoc(
doc(db,"users",user.uid),
{
balance:newBalance,
mining:true
}
);

alert("Mining Started");

}

async function withdraw(){

if(balance < 100){

alert("Minimum Withdraw 100 UMJ");

return;

}

await updateDoc(
doc(db,"users",user.uid),
{
withdrawPending:true
}
);

alert("Withdraw Request Sent");

}

async function invest(){

if(balance < 50){

alert("Need 50 UMJ");

return;

}

const newBalance =
balance - 50;

const newInvestment =
investment + 50;

setBalance(newBalance);

setInvestment(newInvestment);

await updateDoc(
doc(db,"users",user.uid),
{
balance:newBalance,
investment:newInvestment
}
);

alert("Investment Activated");

}

async function saveWallet(){

await updateDoc(
doc(db,"users",user.uid),
{
walletAddress
}
);

alert("Wallet Saved");

}

function copyReferral(){

navigator.clipboard.writeText(
"https://umjar.app/ref/" +
user.uid
);

alert("Referral Link Copied");

}

return(

<div className="min-h-screen bg-black text-white p-4 pb-32">

<h1 className="text-5xl font-bold text-yellow-400 text-center mb-6">
UMJAR
</h1>

<div className="bg-zinc-900 p-5 rounded-3xl border border-yellow-500">

<h2 className="text-5xl font-bold text-yellow-400">
