import React, { useState, useEffect } from "react";

import { initializeApp } from "firebase/app";

import {
  getAuth,
  createUserWithEmailAndPassword,
  signInWithEmailAndPassword,
  signOut
} from "firebase/auth";

import {
  getFirestore,
  doc,
  setDoc,
  getDoc,
  updateDoc
} from "firebase/firestore";

const firebaseConfig = {
  apiKey: "AIzaSyAmLTvCWirFSpbpEpQTDX-4p3JAarIr3R4",
  authDomain: "umjar-mining.firebaseapp.com",
  projectId: "umjar-mining",
  storageBucket: "umjar-mining.firebasestorage.app",
  messagingSenderId: "908328509401",
  appId: "1:908328509401:web:7e7e8ceb078efe500c43c8",
  measurementId: "G-TE3NN8W0HT"
};

const app = initializeApp(firebaseConfig);

const auth = getAuth(app);

const db = getFirestore(app);

export default function UMJARMiningApp() {

  const [email, setEmail] = useState("");

  const [password, setPassword] = useState("");

  const [balance, setBalance] = useState(0);

  const [user, setUser] = useState(null);

  const [mining, setMining] = useState(false);

  async function signup() {

    try {

      const res = await createUserWithEmailAndPassword(
        auth,
        email,
        password
      );

      await setDoc(doc(db, "users", res.user.uid), {
        email,
        balance: 0,
        mining: false
      });

      alert("Signup Success");

    } catch (err) {

      alert(err.message);

    }

  }

  async function login() {

    try {

      const res = await signInWithEmailAndPassword(
        auth,
        email,
        password
      );

      setUser(res.user);

      const ref = doc(db, "users", res.user.uid);

      const snap = await getDoc(ref);

      if (snap.exists()) {

        setBalance(snap.data().balance);

        setMining(snap.data().mining);

      }

      alert("Login Success");

    } catch (err) {

      alert(err.message);

    }

  }

  async function logout() {

    await signOut(auth);

    setUser(null);

    alert("Logged Out");

  }

  async function startMining() {

    if (!user) {

      alert("Login First");

      return;

    }

    const newBalance = balance + 10;

    setBalance(newBalance);

    setMining(true);

    await updateDoc(
      doc(db, "users", user.uid),
      {
        balance: newBalance,
        mining: true
      }
    );

  }

  return (

    <div className="min-h-screen bg-black text-white p-4">

      <h1 className="text-5xl font-bold text-yellow-400 text-center mb-6">
        UMJAR
      </h1>

      <div className="bg-zinc-900 p-5 rounded-3xl border border-yellow-500">

        <h2 className="text-5xl font-bold text-yellow-400">
          {balance} UMJ
        </h2>

        <p className="text-green-400 mt-2 break-all">
          {user?.email}
        </p>

        <input
          type="email"
          placeholder="Email"
          className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
          onChange={(e)=>setEmail(e.target.value)}
        />

        <input
          type="password"
          placeholder="Password"
          className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
          onChange={(e)=>setPassword(e.target.value)}
        />

        <button
          onClick={signup}
          className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
        >
          SIGN UP
        </button>

        <button
          onClick={login}
          className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
        >
          LOGIN
        </button>

        <button
          onClick={logout}
          className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
        >
          LOGOUT
        </button>

        <div className="w-48 h-48 rounded-full border-8 border-yellow-500 mx-auto mt-10 flex items-center justify-center animate-pulse">

          <h2 className="text-3xl text-yellow-400 font-bold">
            MINING
          </h2>

        </div>

        <div className="text-center mt-6">

          <p className="text-5xl text-yellow-400">
            {balance}
          </p>

          <p className="text-green-400 mt-2">
            {mining ? "Mining Active" : "Mining Stopped"}
          </p>

        </div>

        <button
          onClick={startMining}
          className="w-full bg-yellow-500 text-black font-bold py-5 rounded-2xl mt-8 text-2xl"
        >
          START MINING
        </button>

      </div>

    </div>

  );

}
