import React, { useState, useEffect } from "react";

import { initializeApp } from "firebase/app";

import {
  getAuth,
  createUserWithEmailAndPassword,
  signInWithEmailAndPassword,
  signOut,
  onAuthStateChanged
} from "firebase/auth";

import {
  getFirestore,
  doc,
  setDoc,
  getDoc,
  updateDoc
} from "firebase/firestore";

const firebaseConfig = {
  apiKey: "AIzaSyAmLTvCWirFSpbpEpQTDX-4p3JAarIr3R4",
  authDomain: "umjar-mining.firebaseapp.com",
  projectId: "umjar-mining",
  storageBucket: "umjar-mining.firebasestorage.app",
  messagingSenderId: "908328509401",
  appId: "1:908328509401:web:7e7e8ceb078efe500c43c8",
  measurementId: "G-TE3NN8W0HT"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);

export default function UMJARExchange() {

  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");

  const [user, setUser] = useState(null);

  const [balance, setBalance] = useState(0);
  const [mining, setMining] = useState(false);
  const [investment, setInvestment] = useState(0);
  const [referrals, setReferrals] = useState(0);
  const [walletAddress, setWalletAddress] = useState("");

  const [coins, setCoins] = useState([]);

  // LOAD MARKET
  useEffect(() => {

    async function loadCoins() {
      try {

        const res = await fetch(
          "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=bitcoin,ethereum,solana,binancecoin"
        );

        const data = await res.json();

        setCoins(data);

      } catch (err) {
        console.log(err);
      }
    }

    loadCoins();

  }, []);

  // AUTH STATE
  useEffect(() => {

    const unsub = onAuthStateChanged(auth, async(currentUser) => {

      if(currentUser){

        setUser(currentUser);

        const ref = doc(db, "users", currentUser.uid);

        const snap = await getDoc(ref);

        if(snap.exists()){

          const data = snap.data();

          setBalance(data.balance || 0);
          setMining(data.mining || false);
          setInvestment(data.investment || 0);
          setReferrals(data.referrals || 0);
          setWalletAddress(data.walletAddress || "");

        }

      } else {

        setUser(null);

      }

    });

    return () => unsub();

  }, []);

  // SIGNUP
  async function signup(){

    if(!email || !password){
      alert("Enter Email And Password");
      return;
    }

    try{

      const res = await createUserWithEmailAndPassword(
        auth,
        email,
        password
      );

      await setDoc(
        doc(db,"users",res.user.uid),
        {
          email,
          balance:0,
          mining:false,
          investment:0,
          referrals:0,
          walletAddress:"",
          withdrawPending:false
        }
      );

      alert("Signup Success");

    }catch(err){

      alert(err.message);

    }

  }

  // LOGIN
  async function login(){

    try{

      await signInWithEmailAndPassword(
        auth,
        email,
        password
      );

      alert("Login Success");

    }catch(err){

      alert(err.message);

    }

  }

  // LOGOUT
  async function logout(){

    await signOut(auth);

    alert("Logged Out");

  }

  // MINING
  async function startMining(){

    if(!user){
      alert("Login First");
      return;
    }

    if(mining){
      alert("Mining Already Active");
      return;
    }

    try{

      const newBalance = balance + 10;

      setBalance(newBalance);
      setMining(true);

      await updateDoc(
        doc(db,"users",user.uid),
        {
          balance:newBalance,
          mining:true
        }
      );

      alert("Mining Started");

    }catch(err){

      alert(err.message);

    }

  }

  // WITHDRAW
  async function withdraw(){

    if(!user){
      alert("Login First");
      return;
    }

    if(balance < 100){
      alert("Minimum Withdraw 100 UMJ");
      return;
    }

    try{

      await updateDoc(
        doc(db,"users",user.uid),
        {
          withdrawPending:true
        }
      );

      alert("Withdraw Request Sent");

    }catch(err){

      alert(err.message);

    }

  }

  // INVEST
  async function invest(){

    if(!user){
      alert("Login First");
      return;
    }

    if(balance < 50){
      alert("Need 50 UMJ");
      return;
    }

    try{

      const newBalance = balance - 50;
      const newInvestment = investment + 50;

      setBalance(newBalance);
      setInvestment(newInvestment);

      await updateDoc(
        doc(db,"users",user.uid),
        {
          balance:newBalance,
          investment:newInvestment
        }
      );

      alert("Investment Activated");

    }catch(err){

      alert(err.message);

    }

  }

  // SAVE WALLET
  async function saveWallet(){

    if(!user){
      alert("Login First");
      return;
    }

    try{

      await updateDoc(
        doc(db,"users",user.uid),
        {
          walletAddress
        }
      );

      alert("Wallet Saved");

    }catch(err){

      alert(err.message);

    }

  }

  // REFERRAL
  function copyReferral(){

    if(!user){
      alert("Login First");
      return;
    }

    navigator.clipboard.writeText(
      "https://umjar.app/ref/" + user.uid
    );

    alert("Referral Link Copied");

  }

  return(

    <div className="min-h-screen bg-black text-white p-4 pb-32">

      <h1 className="text-5xl font-bold text-yellow-400 text-center mb-6">
        UMJAR
      </h1>

      <div className="bg-zinc-900 p-5 rounded-3xl border border-yellow-500">

        <h2 className="text-5xl font-bold text-yellow-400">
          {balance} UMJ
        </h2>

        <p className="text-green-400 mt-2 break-all">
          {user?.email}
        </p>

        <input
          type="email"
          placeholder="Email"
          className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
          onChange={(e)=>setEmail(e.target.value)}
        />

        <input
          type="password"
          placeholder="Password"
          className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
          onChange={(e)=>setPassword(e.target.value)}
        />

        <button
          onClick={signup}
          className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
        >
          SIGN UP
        </button>

        <button
          onClick={login}
          className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
        >
          LOGIN
        </button>

        <button
          onClick={logout}
          className="w-full bg-red-500 text-white font-bold py-4 rounded-2xl mt-4"
        >
          LOGOUT
        </button>

      </div>

    </div>

  );

}
