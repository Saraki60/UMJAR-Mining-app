</h2>

<p className="text-green-400 mt-2 break-all">
{user?.email}
</p>

<input
type="email"
placeholder="Email"
className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
onChange={(e)=>setEmail(e.target.value)}
/>

<input
type="password"
placeholder="Password"
className="w-full mt-4 p-4 rounded-2xl bg-zinc-800"
onChange={(e)=>setPassword(e.target.value)}
/>

<button
onClick={signup}
className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
>
SIGN UP
</button>

<button
onClick={login}
className="w-full bg-yellow-500 text-black font-bold py-4 rounded-2xl mt-4"
>
